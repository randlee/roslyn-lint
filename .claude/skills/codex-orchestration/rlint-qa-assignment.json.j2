---
name: rlint-qa-assignment
version: 1.0.0
description: Render a fenced-JSON assignment for rlint-qa.
format: json
required_variables:
  - review_mode
  - worktree_path
optional_variables:
  - phase
  - sprint
  - review_targets
  - run_restore
  - run_format
  - run_build
  - run_tests
  - run_coverage
  - baseline_ref
  - artifact_regeneration_required
  - artifact_commands
  - round_limit
  - changed_files
  - carry_forward_findings_json
  - triage_records
  - notes
defaults:
  phase: ""
  sprint: ""
  review_targets: []
  run_restore: true
  run_format: false
  run_build: true
  run_tests: true
  run_coverage: false
  baseline_ref: ""
  artifact_regeneration_required: false
  artifact_commands: ""
  round_limit: false
  changed_files: []
  carry_forward_findings_json: "[]"
  triage_records: []
  notes: ""
---
{
  "worktree_path": "{{ worktree_path }}",
  "review_mode": "{{ review_mode }}",
  "scope": {
    "phase": {% if phase %}"{{ phase }}"{% else %}null{% endif %},
    "sprint": {% if sprint %}"{{ sprint }}"{% else %}null{% endif %}
  },
  "review_targets": [{% for target in review_targets %}"{{ target }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "run_checks": {
    "restore": {% if run_restore %}true{% else %}false{% endif %},
    "format": {% if run_format %}true{% else %}false{% endif %},
    "build": {% if run_build %}true{% else %}false{% endif %},
    "tests": {% if run_tests %}true{% else %}false{% endif %},
    "coverage": {% if run_coverage %}true{% else %}false{% endif %}
  },
  "baseline_ref": {% if baseline_ref %}"{{ baseline_ref }}"{% else %}null{% endif %},
  "artifact_regeneration_required": {% if artifact_regeneration_required %}true{% else %}false{% endif %},
  "artifact_commands": "{{ artifact_commands }}",
  "round_limit": {% if round_limit %}true{% else %}false{% endif %},
  "changed_files": [{% for file in changed_files %}"{{ file }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "triage_records": [{% for record in triage_records %}"{{ record }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "carry_forward_findings": {{ carry_forward_findings_json }},
  "notes": "{{ notes }}"
}
