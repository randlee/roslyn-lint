---
name: sprint-plan
version: 1.0.0
description: Generate a sprint plan document for roslyn-lint phases.
format: markdown
required_variables:
  - id
  - title
  - branch
  - target
optional_variables:
  - status
  - worktree
  - goal
  - dependencies
  - exact_targets
  - required_work
  - acceptance_criteria
  - validation
defaults:
  status: planned
  worktree: ""
  goal: []
  dependencies: []
  exact_targets: []
  required_work: []
  acceptance_criteria: []
  validation:
    - "dotnet restore roslyn-lint.sln"
    - "dotnet build roslyn-lint.sln --configuration Release"
    - "dotnet test roslyn-lint.sln --configuration Release --verbosity normal"
    - "git diff --check"
---
---
id: {{ id }}
title: {{ title }}
status: {{ status }}
branch: {{ branch }}
{% if worktree %}worktree: {{ worktree }}
{% endif %}target: {{ target }}
---

# Sprint {{ id }} — {{ title }}

## Goal

{% for item in goal %}- {{ item }}
{% endfor %}
## Hard Dependencies

{% for dep in dependencies %}- {{ dep }}
{% endfor %}
## Exact Targets

{% for file in exact_targets %}- `{{ file }}`
{% endfor %}
## Required Work

{% for item in required_work %}- {{ item }}
{% endfor %}
## Acceptance Criteria

{% for criterion in acceptance_criteria %}- {{ criterion }}
{% endfor %}
## Required Validation

{% for cmd in validation %}- `{{ cmd }}`
{% endfor %}
