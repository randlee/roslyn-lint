      {"matcher": "resume", "hooks": [{"type": "command", "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_start_context.py\" --mode resume --atm-team \"$ATM_TEAM\" --atm-identity \"$ATM_IDENTITY\""}]},
